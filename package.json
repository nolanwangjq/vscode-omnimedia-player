{
  "name": "omnimedia-player",
  "displayName": "Omnimedia Player",
  "description": "Play MP4, WebM, MOV, MKV, and AVI videos directly inside VS Code with full audio support, no file size limits, playback speed control, and Picture-in-Picture.",
  "version": "0.3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nolanwangjq/vscode-omnimedia-player"
  },
  "publisher": "nolanwang",
  "icon": "images/logo.png",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nolanwangjq/vscode-omnimedia-player/issues"
  },
  "homepage": "https://batchnepal.com",
  "keywords": [
    "video",
    "preview",
    "player",
    "media",
    "video player",
    "video preview",
    "Codec",
    "mp4",
    "mkv",
    "webm"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onFileSystem:**/*.mp4",
    "onFileSystem:**/*.webm",
    "onFileSystem:**/*.mov",
    "onFileSystem:**/*.mkv",
    "onFileSystem:**/*.avi",
    "onFileSystem:**/*.m4v"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Omnimedia Player",
      "properties": {
        "videoPreview.externalPlayerPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "Path to an external video player executable (e.g. C:\\Program Files\\PotPlayer\\PotPlayerMini64.exe). When set, 'Open in External Player' launches this player instead of the system default. Only used in local (non-remote) VS Code sessions."
        }
      }
    },
    "commands": [
      {
        "command": "videoPreview.open",
        "title": "Open with Omnimedia Player"
      }
    ],
    "customEditors": [
  {
    "viewType": "videoPreview.viewer",
    "displayName": "Omnimedia Player",
    "priority": "default",
    "readonly": true,
    "selector": [
      { "filenamePattern": "**/*.mp4" },
      { "filenamePattern": "**/*.webm" },
      { "filenamePattern": "**/*.mov" },
      { "filenamePattern": "**/*.mkv" },
      { "filenamePattern": "**/*.avi" },
      { "filenamePattern": "**/*.m4v" }
    ]
  }
]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w",
    "lint": "echo 'add eslint if you like'",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
